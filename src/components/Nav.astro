---
// src/components/Nav.astro — Header desktop redesigné
import { SITE } from '../config';

// Prestations de nettoyage affichées dans le méga-menu.
// Tant que les pages services dédiées n'existent pas, chaque entrée pointe vers
// la section correspondante de la page d'accueil (#ancre). Quand les pages
// /services/... seront créées, remplacer href par `/services/<slug>/`.
const services = [
  { slug: 'nettoyage-bureaux',     nom: 'Nettoyage de bureaux',     desc: 'Espaces de travail sains et nets' },
  { slug: 'parties-communes',      nom: 'Parties communes',         desc: 'Halls, escaliers, copropriétés' },
  { slug: 'surfaces-vitrees',      nom: 'Surfaces vitrées',         desc: 'Vitres, vitrines, vérandas' },
  { slug: 'nettoyage-sols',        nom: 'Nettoyage des sols',       desc: 'Autolaveuse, monobrosse, moquettes' },
  { slug: 'espaces-verts',         nom: 'Entretien des espaces verts', desc: 'Tonte, haies, abords' },
  { slug: 'haute-pression',        nom: 'Nettoyage haute pression', desc: 'Façades, terrasses, parkings' },
];
---

<header class="hd">
  <div class="container hd__inner">

    <!-- Logo gauche -->
    <a href="/" class="logo" aria-label={`Accueil — ${SITE.nom}`}>
      <picture>
        <source srcset="/assets/img/logo/logo.webp" type="image/webp">
        <img src="/assets/img/logo/logo.png" alt={SITE.nom} width="134" height="56" decoding="async">
      </picture>
    </a>

    <!-- Nav centrée -->
    <nav class="nav-new" id="nav" aria-label="Navigation principale">
      <ul class="nav-new__list">
        <li><a href="/" class="nav-new__link">Accueil</a></li>

        <li class="nav-new__dd">
          <a href="/#prestations" class="nav-new__link nav-new__link--has-dd">
            Nos prestations
            <svg width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
              <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round"/>
            </svg>
          </a>
          <div class="nav-new__mega" role="menu">
            <div class="nav-new__mega-grid">
              {services.map(s => (
                <a href={`/#${s.slug}`} class="nav-new__mega-item" role="menuitem">
                  <strong>{s.nom}</strong>
                  <small>{s.desc}</small>
                </a>
              ))}
            </div>
            <a href="/#prestations" class="nav-new__mega-foot">Voir toutes nos prestations →</a>
          </div>
        </li>

        <li><a href="/galerie/" class="nav-new__link">Galerie</a></li>
        <li><a href="/a-propos/" class="nav-new__link">À propos</a></li>
        <li><a href="/contact/" class="nav-new__link">Contact</a></li>
      </ul>

      <!-- Bloc CTA dans le menu mobile (tel + devis + WhatsApp) -->
      <div class="nav__mobile-cta">
        <div class="nav__mobile-cta-title">Me joindre</div>
        <a href={`tel:${SITE.telLink}`} class="nav__mobile-tel">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
          {SITE.tel}
        </a>
        <a href="/contact/" class="nav__mobile-devis">Envoyer un message</a>
        <a href={`https://wa.me/33${SITE.telLink.replace(/^0/, '')}`} class="nav__mobile-wa" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </nav>

    <!-- CTA Devis — visible desktop + tablette uniquement (caché en mobile) -->
    <a href="/contact/" class="hd__cta-devis">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="9" y1="13" x2="15" y2="13"/>
        <line x1="9" y1="17" x2="13" y2="17"/>
      </svg>
      Envoyer un message
    </a>

    <!-- Burger mobile -->
    <button class="burger" id="burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

  </div>
</header>


<!-- ============================================================
     FAB — Bouton flottant animé + popup contact
     ============================================================ -->
<div class="fab" id="fab">
  <button class="fab__btn" id="fab-btn" aria-label="Nous contacter" aria-expanded="false">
    <span class="fab__rotor"></span>
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/>
    </svg>
  </button>

  <div class="fab__popup" id="fab-popup">
    <button class="fab__popup-close" id="fab-close" aria-label="Fermer">&times;</button>
    <div class="fab__popup-header">
      <span class="fab__popup-logo">
        <img src="/assets/img/logo/logo.png" alt={SITE.nom} loading="lazy">
      </span>
      <div>
        <div class="fab__popup-name">NPG Nettoyage<span class="fab__popup-online"></span></div>
        <div class="fab__popup-role">Entreprise de nettoyage — Essonne (91)</div>
      </div>
    </div>
    <div class="fab__popup-body">
      <div class="fab__popup-msg">Besoin d'un devis de nettoyage dans l'Essonne ? Nous vous rappelons rapidement ou envoyez votre demande en ligne.</div>
      <div class="fab__popup-actions">
        <a href={`tel:${SITE.telLink}`} class="btn btn--red btn--full">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
          {SITE.tel}
        </a>
        <a href={`https://wa.me/33${SITE.telLink.replace(/^0/, '')}`} class="btn btn--wa btn--full" target="_blank" rel="noopener" aria-label="Discuter sur WhatsApp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <a href="/contact/" class="btn btn--blue btn--full">Envoyer un message</a>
      </div>
    </div>
  </div>
</div>


<style is:global>
/* ============================================================
   HEADER DESKTOP — version retravaillée (v3 + scroll-hide)
   ============================================================ */

/* Header sticky avec disparition douce au scroll */
.hd {
  transition: transform .35s cubic-bezier(.4,0,.2,1), box-shadow .35s ease;
  will-change: transform;
}
.hd.is-hidden { transform: translateY(-100%); }
.hd.is-scrolled { box-shadow: 0 4px 18px rgba(0,0,0,.08); }

/* Logo plus grand, sans filter blanc */
.hd .logo img {
  height: 56px !important;
  width: auto;
  filter: none !important;
  display: block;
}

/* === Navigation centrale === */
.nav-new {
  display: flex;
  align-items: center;
  gap: .25rem;
  flex: 1;
  justify-content: center;
}
.nav-new__list {
  list-style: none; padding: 0; margin: 0;
  display: flex;
  align-items: center;
  gap: .35rem;
}
.nav-new__link {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  padding: .6rem 1rem;
  border-radius: 8px;
  color: var(--blue-d);
  font-size: .92rem;
  font-weight: 600;
  text-decoration: none;
  transition: all var(--transition);
  position: relative;
}
.nav-new__link::after {
  content: "";
  position: absolute;
  bottom: 4px; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 2px;
  background: var(--red);
  transition: width var(--transition);
}
.nav-new__link:hover { color: var(--red); }
.nav-new__link:hover::after { width: calc(100% - 2rem); }
.nav-new__link svg { transition: transform var(--transition); }
.nav-new__link--has-dd svg { color: var(--muted); }

/* === Mega menu Services === */
.nav-new__dd { position: relative; }
.nav-new__dd:hover .nav-new__link svg { transform: rotate(180deg); color: var(--red); }
.nav-new__mega {
  display: none;
  position: absolute;
  top: calc(100% + .5rem);
  left: 50%;
  transform: translateX(-50%);
  background: var(--white);
  border-radius: 16px;
  box-shadow: 0 16px 48px rgba(0,0,0,.18);
  padding: 1.2rem;
  width: 720px;
  max-width: 90vw;
  z-index: 200;
}
.nav-new__mega::before {
  content: "";
  position: absolute;
  top: -.6rem; left: 0; right: 0;
  height: .6rem;
}
.nav-new__dd:hover .nav-new__mega,
.nav-new__dd:focus-within .nav-new__mega { display: block; }

.nav-new__mega-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .35rem;
}
.nav-new__mega-item {
  display: block;
  padding: .85rem 1rem;
  border-radius: 10px;
  text-decoration: none;
  transition: background var(--transition);
  border-left: 3px solid transparent;
}
.nav-new__mega-item:hover {
  background: var(--blue-l);
  border-left-color: var(--red);
}
.nav-new__mega-item strong {
  display: block;
  color: var(--blue-d);
  font-size: .92rem;
  font-weight: 700;
  margin-bottom: .15rem;
}
.nav-new__mega-item small {
  display: block;
  color: var(--muted);
  font-size: .78rem;
  line-height: 1.4;
}
.nav-new__mega-foot {
  display: block;
  text-align: center;
  margin-top: .85rem;
  padding-top: .85rem;
  border-top: 1px solid var(--border);
  color: var(--red);
  font-size: .88rem;
  font-weight: 700;
  text-decoration: none;
  transition: color var(--transition);
}
.nav-new__mega-foot:hover { color: var(--red-d); }

/* === Bloc CTA droite : tel + bouton === */
.hd-new__cta {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-shrink: 0;
}
.hd-new__tel {
  display: inline-flex;
  align-items: center;
  gap: .65rem;
  text-decoration: none;
  color: var(--blue-d);
  transition: color var(--transition);
}
.hd-new__tel:hover { color: var(--red); }
.hd-new__tel-icon {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: var(--blue-l);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--blue);
  transition: all var(--transition);
}
.hd-new__tel:hover .hd-new__tel-icon { background: var(--red); color: var(--white); }
.hd-new__tel-icon svg { width: 18px; height: 18px; }
.hd-new__tel-txt { display: flex; flex-direction: column; line-height: 1.1; }
.hd-new__tel-txt small {
  font-size: .68rem;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: var(--muted);
}
.hd-new__tel-txt strong {
  font-size: .98rem;
  font-weight: 800;
  letter-spacing: -.01em;
}
.hd-new__btn {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  padding: .7rem 1.4rem;
  border-radius: 999px;
  background: var(--red);
  color: var(--white);
  font-size: .9rem;
  font-weight: 700;
  text-decoration: none;
  box-shadow: 0 6px 18px rgba(192,57,43,.3);
  transition: all var(--transition);
  white-space: nowrap;
}
.hd-new__btn:hover { background: var(--red-d); transform: translateY(-2px); box-shadow: 0 10px 26px rgba(192,57,43,.4); }

/* ============================================================
   MENU OVERLAY — apparaît quand .is-open (desktop scroll-hide ou mobile)
   ============================================================ */
.nav-new.is-open {
  position: fixed;
  top: 0; right: 0;
  width: min(380px, 90vw);
  height: 100vh;
  background: var(--white);
  box-shadow: -10px 0 40px rgba(0,0,0,.18);
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  padding: 5rem 0 2rem;
  z-index: 98;
  overflow-y: auto;
  animation: nav-slide-in .35s cubic-bezier(.4,0,.2,1) both;
}
@keyframes nav-slide-in {
  from { transform: translateX(100%); }
  to   { transform: translateX(0); }
}

.nav-new.is-open .nav-new__list {
  display: flex !important;
  flex-direction: column;
  align-items: stretch;
  gap: 0;
  padding: 0 1.25rem;
}
.nav-new.is-open .nav-new__link {
  padding: 1rem .25rem;
  border-bottom: 1px solid var(--border);
  border-radius: 0;
  font-size: 1rem;
  justify-content: space-between;
}
.nav-new.is-open .nav-new__link::after { display: none; }
.nav-new.is-open .nav-new__mega { display: none !important; }
.nav-new.is-open .nav__mobile-cta { display: flex; }

/* Voile noir derrière le menu */
.nav-new.is-open::before {
  content: "";
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.5);
  z-index: -1;
  animation: fade-in .25s ease both;
}
@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ============================================================
   CTA Devis dans le header — visible desktop + tablette uniquement
   ============================================================ */
.hd__cta-devis {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .65rem 1.1rem;
  background: var(--red);
  color: var(--white);
  font-size: .9rem;
  font-weight: 700;
  text-decoration: none;
  border-radius: 8px;
  box-shadow: 0 6px 16px rgba(192,57,43,.28);
  transition: all var(--transition);
  white-space: nowrap;
  flex-shrink: 0;
  margin-left: 1rem;
}
.hd__cta-devis:hover {
  background: var(--red-d);
  transform: translateY(-1px);
  box-shadow: 0 8px 20px rgba(192,57,43,.36);
}
.hd__cta-devis svg { flex-shrink: 0; }

/* === Responsive : nav inline cachée en mobile (le menu ne s'affiche que via overlay) === */
@media (max-width: 980px) {
  .nav-new:not(.is-open) .nav-new__list { display: none; }
}

/* CTA Devis : caché uniquement sur mobile (≤768px), reste visible sur tablette */
@media (max-width: 768px) {
  .hd__cta-devis { display: none; }
}

/* ============================================================
   MENU MOBILE — bloc CTA tel + devis + WhatsApp
   ============================================================ */
.nav__mobile-cta {
  display: none;  /* visible uniquement quand .nav.is-open en mobile */
  flex-direction: column;
  gap: .55rem;
  padding: 1.2rem 1.25rem 1rem;
  margin: 1rem 1.25rem 0;
  background: linear-gradient(180deg, #f8f9fb 0%, #ffffff 100%);
  border: 1px solid var(--border);
  border-radius: 12px;
  align-items: stretch;
}
.nav__mobile-cta-title {
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--muted, #6b7280);
  margin: 0 0 .35rem;
  text-align: center;
}
.nav__mobile-tel,
.nav__mobile-devis,
.nav__mobile-wa {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .5rem;
  padding: .65rem 1rem;
  border-radius: 8px;
  font-weight: 700;
  font-size: .9rem;
  text-decoration: none;
  transition: all var(--transition);
  max-width: 260px;
  width: 100%;
  margin: 0 auto;
}
.nav__mobile-tel {
  background: var(--blue-d);
  color: var(--white);
}
.nav__mobile-tel:hover { background: var(--blue); }
.nav__mobile-devis {
  background: var(--red);
  color: var(--white);
}
.nav__mobile-devis:hover { background: var(--red-d); }
.nav__mobile-wa {
  background: #25D366;
  color: var(--white);
}
.nav__mobile-wa:hover { background: #128C7E; }

/* ============================================================
   FAB POPUP — logo NPG
   ============================================================ */
.fab__popup-logo {
  width: 48px; height: 48px;
  border-radius: 12px;
  background: var(--white);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0,0,0,.12);
  padding: 4px;
}
.fab__popup-logo img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  filter: none !important;
  opacity: 1 !important;
}
</style>

<!-- ============================================================
     SCROLL-HIDE HEADER + FAB BURGER (mobile menu toggle)
     ============================================================ -->
<script is:inline>
(function () {
  const hd     = document.querySelector('.hd');
  const burger = document.getElementById('burger');
  const nav    = document.getElementById('nav');

  if (!hd) return;

  // Pattern "scroll up to reveal" : on cache le header quand on scroll vers le bas
  // ET qu'on a dépassé un seuil minimum, on le révèle dès qu'on scroll vers le haut.
  // Plus naturel que la simple disparition au-delà d'un seuil fixe.
  const MIN_HIDE_THRESHOLD = () => (window.innerWidth >= 980 ? 1200 : 900);
  let lastY = 0;
  let ticking = false;

  function update() {
    const y = window.scrollY;
    const delta = y - lastY;

    // Header masqué seulement si :
    //  - on a dépassé le seuil de scroll minimum
    //  - ET on est en train de descendre (delta > 4px pour éviter les micro-scrolls)
    if (y > MIN_HIDE_THRESHOLD() && delta > 4) {
      hd.classList.add('is-hidden');
    } else if (delta < -4 || y <= 50) {
      // On scroll vers le haut OU on est presque tout en haut → réafficher
      hd.classList.remove('is-hidden');
    }

    if (y > 8) hd.classList.add('is-scrolled');
    else hd.classList.remove('is-scrolled');

    lastY = y;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(update);
      ticking = true;
    }
  }, { passive: true });

  // === Helpers menu ouvert / fermé (uniquement burger header) ===
  function setMenuOpen(open) {
    if (!nav) return;
    nav.classList.toggle('is-open', open);
    document.body.classList.toggle('nav-locked', open);
    if (burger) {
      burger.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    }
  }
  function toggleMenu() {
    setMenuOpen(!nav.classList.contains('is-open'));
  }

  if (burger) burger.addEventListener('click', toggleMenu);

  if (nav) {
    nav.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => setMenuOpen(false));
    });
    nav.addEventListener('click', (e) => {
      if (e.target === nav) setMenuOpen(false);
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && nav && nav.classList.contains('is-open')) {
      setMenuOpen(false);
    }
  });

  update();
})();
</script>

<style is:global>
/* Body : empêche le scroll quand le menu est ouvert (classe ajoutée par JS) */
body.nav-locked { overflow: hidden; }
</style>
