---
// src/pages/devis-gratuit.astro
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';

const IMG = '/assets/img/photos-npg';

// Types de prestations proposés dans le formulaire
const PRESTATIONS = [
  ['nettoyage-bureaux',  'Nettoyage de bureaux / locaux'],
  ['parties-communes',   'Parties communes de copropriété'],
  ['surfaces-vitrees',   'Surfaces vitrées (vitres, vitrines)'],
  ['nettoyage-sols',     'Nettoyage et entretien des sols'],
  ['moquettes',          'Shampooing de moquettes'],
  ['espaces-verts',      'Entretien des espaces verts'],
  ['haute-pression',     'Nettoyage haute pression'],
  ['fin-de-chantier',    'Nettoyage de fin de chantier'],
  ['autre',              'Autre / plusieurs prestations'],
];

const schema = {
  '@context':  'https://schema.org',
  '@type':     'Service',
  name:        "Devis de nettoyage gratuit dans l'Essonne",
  provider:    { '@type': 'CleaningService', name: SITE.nom },
  areaServed:  { '@type': 'AdministrativeArea', name: 'Essonne' },
  offers:      { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
};

const heroPhoto = `${IMG}/camion-npg-devant-residence-npg.webp`;

// Clé publique Turnstile (build-time). Si absente, le widget ne s'affiche pas
// (utile en dev). La vérification serveur se fait dans /api/devis avec le secret.
const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<Layout
  title="Devis de nettoyage gratuit dans l'Essonne (91) — NPG"
  description="Demandez un devis gratuit à NPG, entreprise de nettoyage dans l'Essonne (91). Visite sur place, devis détaillé et sans engagement, intervention dans tout le département."
  canonical={`${SITE.url}/devis-gratuit/`}
  schema={schema}
  lcpImage={heroPhoto}
>

  <!-- ── PAGE HERO avec photo ── -->
  <section class="page-hero" aria-label="Demander un devis de nettoyage dans l'Essonne">
    <div class="container page-hero__inner">

      <div class="page-hero__left">
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a><span>›</span>
          <span>Demander un devis</span>
        </nav>

        <h1>Demander un devis à votre entreprise de nettoyage dans l'Essonne (91)</h1>
        <p class="page-hero__sub">NPG — Nettoyage professionnel multiservices</p>

        <p class="page-hero__desc">
          Vous souhaitez une intervention ponctuelle ou un contrat d'entretien régulier ? Décrivez votre besoin ci-dessous, nous vous recontactons rapidement pour convenir d'une visite. Le devis est établi après évaluation sur place, détaillé et sans engagement.
        </p>

        <ul class="page-hero__list">
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Évaluation sur place avant chaque devis</span>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Devis gratuit, détaillé et sans engagement</span>
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Intervention dans toute l'Essonne (Lun-Ven, 7h-21h)</span>
          </li>
        </ul>

        <div class="page-hero__btns">
          <a href={`tel:${SITE.telLink}`} class="btn btn--red">
            <img src="/assets/icones/telephone.svg" alt="" width="16" height="16" class="icone icone--white">
            {SITE.tel}
          </a>
          <a href="#devis-form" class="btn btn--outline">
            <img src="/assets/icones/devis-gratuit.svg" alt="" width="16" height="16" class="icone icone--white">
            Remplir le formulaire
          </a>
        </div>
      </div>

      <div class="page-hero__img-wrap">
        <img
          src={heroPhoto}
          alt="Véhicule NPG devant une résidence dans l'Essonne pour une intervention de nettoyage"
          width="560" height="420"
          loading="eager"
        />
      </div>

    </div>
  </section>

  <!-- ── CONTENU : 2 colonnes (présentation + formulaire) ── -->
  <div class="content-wrap section--light">
    <div class="container">
      <div class="form-grid">

        <!-- Colonne gauche : présentation, contact, assurance -->
        <div>
          <h2>Besoin d'une prestation de nettoyage&nbsp;?</h2>

          <p>
            Que ce soit pour l'entretien régulier de vos <a href="/#nettoyage-bureaux"><strong>bureaux</strong></a>, le nettoyage des <a href="/#parties-communes"><strong>parties communes</strong></a> de votre copropriété, le lavage de vos <a href="/#surfaces-vitrees"><strong>surfaces vitrées</strong></a>, la remise en état de vos <a href="/#nettoyage-sols"><strong>sols</strong></a> ou l'<a href="/#espaces-verts"><strong>entretien de vos espaces verts</strong></a>, NPG vous propose une solution adaptée à vos besoins et à votre budget. Nous évaluons votre demande sur place, puis nous établissons un devis clair et détaillé.
          </p>

          <h3 style="margin-top:2rem;">Nous joindre directement</h3>
          <ul class="contact-list" style="margin-top:1rem">
            <li>
              <img src="/assets/icones/mobile.svg" alt="" width="18" height="18" class="icone">
              <a href={`tel:${SITE.telLink}`}><strong>{SITE.tel}</strong></a> — Lun-Ven, 7h-21h
            </li>
            <li>
              <img src="/assets/icones/email.svg" alt="" width="18" height="18" class="icone">
              <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
            </li>
          </ul>

          <div class="devis-garantie">
            <div class="devis-garantie__head">
              <strong>Une entreprise assurée</strong>
            </div>
            <p>Toutes nos interventions de nettoyage sont couvertes par une assurance responsabilité civile professionnelle. Nos agents sont formés, suivis et équipés d'un matériel professionnel.</p>
          </div>
        </div>

        <!-- Colonne droite : formulaire -->
        <div class="form-wrap">
          <h3>Décrivez votre besoin</h3>
          <p style="font-size:.92rem;color:var(--muted, #6b7280);margin-bottom:1.5rem;">Quelques informations rapides pour vous rappeler avec une première estimation.</p>

          <form id="devis-form" name="devis" method="POST" action="/api/devis/">
            <!-- Honeypot anti-spam (champ caché qui doit rester vide) -->
            <p style="position:absolute;left:-9999px" aria-hidden="true">
              <label>Ne pas remplir <input name="website" tabindex="-1" autocomplete="off"></label>
            </p>

            <div class="fg">
              <label for="f-nom">Quel est votre nom ?</label>
              <input id="f-nom" type="text" name="nom" required autocomplete="name" placeholder="Comment devons-nous vous appeler ?">
            </div>

            <div class="form-row">
              <div class="fg">
                <label for="f-tel">Votre numéro de téléphone</label>
                <input id="f-tel" type="tel" name="tel" required autocomplete="tel" placeholder="06 12 34 56 78">
              </div>
              <div class="fg">
                <label for="f-email">Votre adresse email</label>
                <input id="f-email" type="email" name="email" required autocomplete="email" placeholder="vous@exemple.com">
              </div>
            </div>

            <div class="fg">
              <label for="f-ville">Où se situent les locaux ?</label>
              <input id="f-ville" type="text" name="ville" required placeholder="Montlhéry, Massy, Évry, Étampes…">
            </div>

            <div class="fg">
              <label for="f-prestation">Quel type de prestation souhaitez-vous ?</label>
              <select id="f-prestation" name="prestation">
                <option value="">— Choisir une prestation —</option>
                {PRESTATIONS.map(([val, label]) => (
                  <option value={val}>{label}</option>
                ))}
              </select>
            </div>

            <div class="fg">
              <label for="f-message">Décrivez votre besoin en quelques mots</label>
              <textarea id="f-message" name="message" rows="4" placeholder="Surface approximative, type de locaux, fréquence souhaitée (ponctuelle, hebdomadaire, mensuelle)…"></textarea>
            </div>

            {turnstileKey && (
              <div class="cf-turnstile" data-sitekey={turnstileKey} data-theme="light" style="margin-bottom:1rem;"></div>
            )}

            <button type="submit" class="btn btn--red btn--full" id="devis-submit">
              <img src="/assets/icones/devis-gratuit.svg" alt="" width="16" height="16" class="icone">
              Envoyer ma demande
            </button>
            <p id="devis-status" role="status" aria-live="polite" style="margin-top:1rem;font-size:.92rem;"></p>
          </form>

          {turnstileKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>}

          <script is:inline>
          (function () {
            var form = document.getElementById('devis-form');
            if (!form) return;
            var status = document.getElementById('devis-status');
            var submit = document.getElementById('devis-submit');
            form.addEventListener('submit', async function (e) {
              e.preventDefault();
              submit.disabled = true;
              status.style.color = '';
              status.textContent = 'Envoi en cours…';
              try {
                var fd = new FormData(form);
                var payload = {};
                fd.forEach(function (v, k) { payload[k] = v; });
                var res = await fetch('/api/devis/', {
                  method: 'POST',
                  headers: { 'content-type': 'application/json', 'accept': 'application/json' },
                  body: JSON.stringify(payload),
                });
                var data = await res.json().catch(function () { return {}; });
                if (res.ok && data.ok) {
                  window.location.href = '/merci/';
                  return;
                }
                status.style.color = '#c0392b';
                status.textContent = data.error || 'Une erreur est survenue. Merci de réessayer ou de nous appeler au 06 82 18 71 14.';
                submit.disabled = false;
                if (window.turnstile) window.turnstile.reset();
              } catch (err) {
                status.style.color = '#c0392b';
                status.textContent = 'Erreur réseau. Merci de réessayer ou de nous appeler au 06 82 18 71 14.';
                submit.disabled = false;
                if (window.turnstile) window.turnstile.reset();
              }
            });
          })();
          </script>
        </div>

      </div>
    </div>
  </div>

  <!-- ── SECTION : Nettoyage de bureaux (lien interne contextualisé) ── -->
  <section class="feature-split">
    <div class="container">
      <div class="feature-split__grid">
        <div class="feature-split__text">
          <span class="feature-split__tag">Professionnels</span>
          <h2>L'entretien régulier de vos bureaux</h2>
          <p>
            Un environnement de travail propre améliore le bien-être des équipes, réduit la propagation des microbes et renvoie une image soignée à vos visiteurs. Nous assurons le dépoussiérage, la désinfection des points de contact, l'aspiration et le lavage des sols, le vidage des corbeilles et l'entretien des sanitaires.
          </p>
          <p>
            Nous adaptons la fréquence et les horaires de passage à votre activité — tôt le matin, en soirée ou pendant les heures creuses — pour ne jamais perturber votre fonctionnement.
          </p>
        </div>
        <div class="feature-split__img">
          <img src={`${IMG}/nettoyage-bureaux-open-space-npg.webp`} alt="Nettoyage de bureaux en open space dans l'Essonne — NPG" width="520" height="360" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── SECTION : Parties communes (image inversée) ── -->
  <section class="feature-split feature-split--reverse section--light">
    <div class="container">
      <div class="feature-split__grid">
        <div class="feature-split__text">
          <span class="feature-split__tag">Copropriétés</span>
          <h2>Le nettoyage des parties communes</h2>
          <p>
            Halls, escaliers, paliers, ascenseurs, locaux poubelles et abords : des parties communes bien entretenues créent une atmosphère agréable et valorisent le patrimoine de la copropriété.
          </p>
          <p>
            Propriétaires et syndics, nous mettons en place un planning d'entretien régulier, avec un suivi des interventions et des comptes rendus, pour garantir des espaces toujours propres et accueillants.
          </p>
        </div>
        <div class="feature-split__img">
          <img src={`${IMG}/nettoyage-escalier-parties-communes-npg.webp`} alt="Nettoyage des parties communes d'un immeuble dans l'Essonne — NPG" width="520" height="360" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

</Layout>
