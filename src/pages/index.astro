---
// src/pages/index.astro — Accueil NPG (entreprise de nettoyage Essonne 91)
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';

const IMG = '/assets/img/photos-npg';
const ICO = '/assets/img/icones-npg';

// === Prestations principales (grille modulaire : 1 grande + 4 mini + bandeaux) ===
// Tant que les pages services dédiées n'existent pas, le CTA renvoie au devis.
// L'attribut `id` permet aux ancres du menu (#nettoyage-bureaux, etc.) de cibler la carte.
const featured = [
  {
    id: 'nettoyage-bureaux',
    title: 'Nettoyage de bureaux',
    subtitle: 'Environnement de travail sain',
    img: `${IMG}/nettoyage-bureaux-professionnel-npg.webp`,
    desc: "Des bureaux propres sont essentiels pour le bien-être de vos équipes comme pour l'image de votre société. Nous assurons l'entretien régulier de vos espaces de travail : dépoussiérage, désinfection des points de contact, aspiration et lavage des sols, vidage des corbeilles, sanitaires. Nous adaptons nos horaires d'intervention à votre activité, tôt le matin ou en soirée.",
    cta: 'Nous contacter',
  },
  {
    id: 'parties-communes',
    title: 'Parties communes',
    subtitle: 'Immeubles & copropriétés',
    img: `${IMG}/nettoyage-parties-communes-immeuble-npg.webp`,
    desc: "Halls, escaliers, paliers, ascenseurs, locaux poubelles : nous entretenons les parties communes de vos résidences et copropriétés. Propriétaires et syndics, nous garantissons des espaces propres qui valorisent votre patrimoine et le cadre de vie des habitants.",
    cta: 'Nous contacter',
  },
  {
    id: 'surfaces-vitrees',
    title: 'Surfaces vitrées',
    subtitle: 'Vitres, vitrines, vérandas',
    img: `${IMG}/nettoyage-surfaces-vitrees-veranda-npg.webp`,
    desc: "Nous assurons le nettoyage professionnel des vitres, vitrines et vérandas dans l'Essonne. Des surfaces vitrées impeccables reflètent l'image et le sérieux de votre entreprise.",
    cta: 'Nous contacter',
  },
  {
    id: 'moquettes',
    title: 'Shampooing de moquettes',
    subtitle: 'Injection-extraction en profondeur',
    img: `${IMG}/nettoyage-moquette-rouge-injection-extraction-npg.webp`,
    desc: "Moquettes de bureaux, escaliers, salles de réception : nous réalisons le shampooing et le nettoyage par injection-extraction qui ravive les couleurs et élimine les taches incrustées, sans détremper la fibre.",
    cta: 'Nous contacter',
  },
  {
    id: 'espaces-verts',
    title: 'Entretien des espaces verts',
    subtitle: 'Tonte, taille, abords',
    img: `${IMG}/tonte-pelouse-entretien-espaces-verts-npg.webp`,
    desc: "Les abords de votre résidence ou de vos locaux participent à la valeur de votre patrimoine. Nous prenons en charge la tonte des pelouses, la taille des haies et arbustes, le débroussaillage et l'entretien des allées et des espaces extérieurs.",
    cta: 'Nous contacter',
  },
  {
    id: 'haute-pression',
    title: 'Nettoyage haute pression',
    subtitle: 'Façades, terrasses, allées, parkings',
    img: `${IMG}/nettoyage-haute-pression-terrasse-npg.webp`,
    desc: "Façades encrassées, terrasses, allées, cours, parkings et locaux poubelles : le nettoyage haute pression élimine en profondeur les salissures, mousses et traces de pollution. Nous redonnons un aspect net à toutes vos surfaces extérieures, dans le respect des supports.",
    cta: 'Nous contacter',
  },
  {
    id: 'nettoyage-sols',
    title: 'Nettoyage des sols',
    subtitle: 'Autolaveuse, monobrosse, cristallisation',
    img: `${IMG}/nettoyage-sols-restaurant-npg.webp`,
    desc: "Carrelage, PVC, béton, parquet : nous remettons en état et entretenons tous vos sols avec un matériel professionnel (autolaveuse, monobrosse, injection-extraction). Une obligation d'hygiène et un vrai confort pour les utilisateurs des locaux.",
    cta: 'Nous contacter',
  },
  {
    id: 'remise-en-etat',
    title: 'Nettoyage de fin de chantier',
    subtitle: 'Remise en état de locaux',
    img: `${IMG}/nettoyage-locaux-professionnels-npg.webp`,
    desc: "Après des travaux ou avant une remise des clés, nous prenons en charge le nettoyage complet et la remise en état de vos locaux : élimination des poussières et résidus de chantier, dégraissage, lustrage des sols et nettoyage des vitres.",
    cta: 'Nous contacter',
  },
];

// === Pourquoi confier votre nettoyage (puces) ===
const checks = [
  { title: "Des locaux propres, reflet du professionnalisme et du sérieux de votre entreprise." },
  { title: "Une meilleure qualité de vie au travail, gage de productivité et de fidélité des salariés." },
  { title: "Des parties communes entretenues qui créent une atmosphère agréable en résidence." },
  { title: "Des espaces verts soignés qui valorisent votre patrimoine immobilier." },
];

// === Nos engagements (remplace les avis) — issus du positionnement NPG ===
const engagements = [
  { ico: `${ICO}/icone-service-qualite-npg.webp`,          titre: 'Un service de qualité',       texte: "La satisfaction de nos clients est au cœur de nos préoccupations. Professionnel ou particulier, il n'y a pas de petit client." },
  { ico: `${ICO}/icone-suivi-professionnel-npg.webp`,      titre: 'Un suivi professionnel',      texte: "Nous assurons le contrôle et le suivi de nos interventions, avec des comptes rendus réguliers à nos clients." },
  { ico: `${ICO}/icone-equipement-professionnel-npg.webp`, titre: 'Un équipement professionnel', texte: "Nous utilisons des équipements adaptés à chaque mission, fournis par les plus grandes marques du secteur." },
  { ico: `${ICO}/icone-hygiene-qualite-npg.webp`,          titre: 'Une équipe expérimentée',     texte: "Nos agents sont formés et suivis. Ils possèdent une expérience solide dans le domaine du nettoyage." },
];

// === Liste élargie des prestations (variantes lexicales pour le référencement) ===
const prestations = [
  { label: "Nettoyage de bureaux",            href: '/#nettoyage-bureaux' },
  { label: "Nettoyage de locaux commerciaux", href: '/#nettoyage-bureaux' },
  { label: "Nettoyage de parties communes",   href: '/#parties-communes' },
  { label: "Nettoyage de halls d'immeubles",  href: '/#parties-communes' },
  { label: "Nettoyage de copropriétés",       href: '/#parties-communes' },
  { label: "Nettoyage de vitres et vitrines", href: '/#surfaces-vitrees' },
  { label: "Nettoyage de sols",               href: '/#nettoyage-sols' },
  { label: "Décapage et cristallisation",     href: '/#nettoyage-sols' },
  { label: "Shampooing de moquettes",         href: '/#moquettes' },
  { label: "Entretien des espaces verts",     href: '/#espaces-verts' },
  { label: "Tonte et taille de haies",        href: '/#espaces-verts' },
  { label: "Nettoyage haute pression",        href: '/#haute-pression' },
  { label: "Nettoyage de parkings",           href: '/#haute-pression' },
  { label: "Nettoyage de terrasses",          href: '/#haute-pression' },
  { label: "Nettoyage de fin de chantier",    href: '/#remise-en-etat' },
];

// === Schema CleaningService (LocalBusiness) ===
const schema = {
  '@context':    'https://schema.org',
  '@type':       ['CleaningService', 'LocalBusiness'],
  '@id':         `${SITE.url}/#organization`,
  name:          SITE.nom,
  alternateName: [
    "NPG Nettoyage",
    "Entreprise de nettoyage Essonne",
    "Entreprise de nettoyage 91",
    "Société de nettoyage Essonne",
    "Nettoyage professionnel 91",
  ],
  description: "Entreprise de nettoyage professionnel multiservices dans l'Essonne (91) : bureaux, locaux professionnels, parties communes de copropriété, surfaces vitrées, sols, moquettes, espaces verts et nettoyage haute pression. Intervention pour les professionnels, syndics et particuliers.",
  url:           SITE.url,
  telephone:     SITE.tel.replace(/\s/g, '').replace(/^0/, '+33'),
  email:         SITE.email,
  image:         `${SITE.url}${SITE.logo}`,
  logo:          `${SITE.url}${SITE.logo}`,
  founder:       { '@type': 'Person', name: SITE.artisan },
  identifier:    { '@type': 'PropertyValue', name: 'SIRET', value: SITE.siret.replace(/\s/g, '') },
  address: {
    '@type':         'PostalAddress',
    streetAddress:   SITE.streetAddress,
    addressLocality: SITE.ville,
    postalCode:      SITE.cp,
    addressRegion:   'Essonne',
    addressCountry:  'FR',
  },
  geo:        { '@type': 'GeoCoordinates', latitude: SITE.geo.lat, longitude: SITE.geo.lng },
  areaServed: { '@type': 'AdministrativeArea', name: 'Essonne', containedInPlace: { '@type': 'State', name: 'Île-de-France' } },
  knowsAbout: [
    "Nettoyage de bureaux", "Nettoyage de locaux professionnels", "Nettoyage de parties communes",
    "Nettoyage de copropriétés", "Nettoyage de surfaces vitrées", "Nettoyage des sols",
    "Shampooing de moquettes", "Entretien des espaces verts", "Nettoyage haute pression",
    "Nettoyage de fin de chantier", "Remise en état de locaux",
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `Prestations de nettoyage NPG dans l'Essonne (91)`,
    itemListElement: featured.map(f => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: f.title },
    })),
  },
  priceRange:         '€€',
  paymentAccepted:    ['Espèces', 'Chèque', 'Virement bancaire'],
  currenciesAccepted: 'EUR',
  openingHours:       'Mo-Fr 07:00-21:00',
};
---

<Layout
  title="Entreprise de nettoyage dans l'Essonne (91) — NPG"
  description="Nettoyage professionnel dans l'Essonne (91) : bureaux, parties communes, vitres, sols et espaces verts. Intervention dans tout le 91, devis sur demande."
  canonical={SITE.url + '/'}
  schema={schema}
  lcpImage="/assets/img/hero/hero.webp"
>

  <!-- ========================================================== -->
  <!-- 1. HERO                                                     -->
  <!-- ========================================================== -->
  <section class="h-hero">
    <div class="h-hero__inner">
      <div class="h-hero__txt">
        <h1 class="h-hero__title">
          <span class="h-hero__line">Société de</span>
          <span class="h-hero__line h-hero__line--accent">nettoyage&nbsp;91<i class="h-hero__underline"></i></span>
        </h1>
        <p class="h-hero__hook">Besoin d'assurer la propreté de vos locaux&nbsp;?</p>
        <p class="h-hero__sub">
          <strong>NPG</strong> est votre interlocuteur du <strong>nettoyage professionnel</strong> dans l'<strong>Essonne&nbsp;(91)</strong> : <strong>bureaux</strong>, <strong>locaux</strong>, <strong>parties communes</strong>, <strong>surfaces vitrées</strong>, <strong>sols</strong> et <strong>espaces verts</strong>. Une équipe expérimentée pour la propreté et l'hygiène de vos espaces, partout dans le département.
        </p>
        <a href={`tel:${SITE.telLink}`} class="h-hero__cta" aria-label={`Appeler le ${SITE.tel}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="6" y="2" width="12" height="20" rx="2.5"/>
            <line x1="11" y1="18" x2="13" y2="18"/>
          </svg>
          {SITE.tel}
        </a>
      </div>
    </div>

    <div class="h-hero__img">
      <picture>
        <source srcset="/assets/img/hero/hero.webp" type="image/webp">
        <img src="/assets/img/hero/hero.webp" alt="Camions NPG, entreprise de nettoyage dans l'Essonne" loading="eager" fetchpriority="high" decoding="async" width="1500" height="1100">
      </picture>
    </div>

    <aside class="h-side">
      <a href={`tel:${SITE.telLink}`} class="h-side__item" aria-label={`Appeler le ${SITE.tel}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="h-side__lbl">Appeler</span>
        <span class="h-side__phone">{SITE.tel}</span>
      </a>
      <a href="/contact/" class="h-side__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
        <span>Message</span>
      </a>
      <a href={`https://wa.me/33${SITE.telLink.replace(/^0/, '')}`} class="h-side__item h-side__item--wa" target="_blank" rel="noopener" aria-label="Discuter sur WhatsApp">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>WhatsApp</span>
      </a>
    </aside>
  </section>

  <!-- ========================================================== -->
  <!-- 2. BANDEAU DE CONFIANCE                                     -->
  <!-- ========================================================== -->
  <section class="h-reviews-wrap">
    <div class="container">
      <h2 class="h-reviews-title">Une entreprise de propreté multiservices dans l'Essonne</h2>
    </div>
    <div class="h-reviews">
      <div class="container h-reviews__inner">
        <span class="h-reviews__txt"><strong>Depuis 2010</strong> à votre service</span>
        <span class="h-reviews__txt">·</span>
        <span class="h-reviews__txt"><strong>Lun-Ven · 7h&ndash;21h</strong></span>
        <span class="h-reviews__txt">·</span>
        <span class="h-reviews__txt">Professionnels, syndics &amp; particuliers</span>
        <span class="h-reviews__txt">·</span>
        <span class="h-reviews__txt"><strong>Tout le département 91</strong></span>
      </div>
    </div>
  </section>

  <!-- ========================================================== -->
  <!-- 2bis. NOS ENGAGEMENTS                                       -->
  <!-- ========================================================== -->
  <section class="h-avis">
    <div class="container">
      <div class="h-avis__grid">
        {engagements.map(e => (
          <article class="h-avis__card">
            <img src={e.ico} alt="" width="56" height="56" loading="lazy" style="width:56px;height:56px;object-fit:contain;margin-bottom:.6rem" />
            <strong class="h-avis__name">{e.titre}</strong>
            <p class="h-avis__txt">{e.texte}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ========================================================== -->
  <!-- 3. POURQUOI ASSURER LA PROPRETÉ                             -->
  <!-- ========================================================== -->
  <section class="h-quick">
    <div class="container">
      <div class="h-quick__panel">
        <div class="h-quick__media">
          <picture>
            <img src={`${IMG}/aspiration-moquette-bureaux-npg.webp`} alt="Agent NPG aspirant la moquette de bureaux dans l'Essonne" class="h-quick__illu" loading="lazy" width="640" height="520">
          </picture>
        </div>
        <div class="h-quick__body">
          <h2 class="h-quick__h2">Pourquoi assurer la propreté de vos locaux&nbsp;?</h2>
          <p class="h-quick__p">Assurer la propreté de vos locaux, de vos bureaux ou des parties communes de votre résidence, c'est garantir un cadre de vie et de travail sain et agréable.</p>
          <ul class="h-quick__list">
            {checks.map(c => (
              <li class="h-quick__item">
                <span class="h-quick__bullet"></span>
                <span>{c.title}</span>
              </li>
            ))}
          </ul>
          <a href="/contact/" class="h-quick__cta">
            Envoyer un message
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================================== -->
  <!-- 4. GRILLE PRESTATIONS                                       -->
  <!-- ========================================================== -->
  <section class="h-prest" id="prestations">
    <div class="container">
      <div class="h-prest__head">
        <span class="h-prest__bar"></span>
        <h2>Nos prestations de nettoyage dans l'Essonne (91)</h2>
      </div>

      <div class="h-prest__grid">
        {featured.slice(0, 1).map(f => (
          <article class="h-prest__hero" id={f.id}>
            <a href="/contact/" class="h-prest__hero-img" style={`background-image:url('${f.img}')`} aria-label={f.title}>
              <span class="h-prest__tag h-prest__tag--big">
                <span class="h-prest__tag-bar"></span>
                <span class="h-prest__tag-content">
                  <strong>{f.title}</strong>
                  {f.subtitle && <em>{f.subtitle}</em>}
                </span>
              </span>
            </a>
            <div class="h-prest__hero-body">
              <p class="h-prest__desc">{f.desc}</p>
              <a href="/contact/" class="h-prest__tile-cta">
                <strong>{f.cta}</strong>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}

        {featured.slice(1, 5).map(f => (
          <a href="/contact/" class="h-prest__mini" id={f.id} style={`background-image:url('${f.img}')`} aria-label={f.title}>
            <span class="h-prest__tag">
              <span class="h-prest__tag-bar"></span>
              <span class="h-prest__tag-content">
                <strong>{f.title}</strong>
                {f.subtitle && <em>{f.subtitle}</em>}
              </span>
            </span>
            <span class="h-prest__mini-cta" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}

        {featured.slice(5).map((f, i) => (
          <article class={`h-prest__band ${i % 2 === 1 ? 'h-prest__band--reverse' : ''}`} id={f.id}>
            <a href="/contact/" class="h-prest__band-img" style={`background-image:url('${f.img}')`} aria-label={f.title}></a>
            <div class="h-prest__band-body">
              <span class="h-prest__tag h-prest__tag--inline">
                <span class="h-prest__tag-bar"></span>
                <span class="h-prest__tag-content">
                  <strong>{f.title}</strong>
                  {f.subtitle && <em>{f.subtitle}</em>}
                </span>
              </span>
              <p class="h-prest__desc">{f.desc}</p>
              <a href="/contact/" class="h-prest__tile-cta">
                <strong>{f.cta}</strong>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="h-prest__cta-wrap">
        <a href="/contact/" class="h-prest__cta">
          <span class="h-prest__cta-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z"/></svg>
          </span>
          Envoyer un message
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M9 18l6-6-6-6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========================================================== -->
  <!-- 5. POURQUOI NOUS CHOISIR                                    -->
  <!-- ========================================================== -->
  <section class="h-why">
    <div class="container">
      <div class="h-why__head">
        <h2>Pourquoi choisir NPG pour le nettoyage de vos espaces</h2>
      </div>
      <div class="h-why__grid">
        <article class="h-why__cell">
          <h3>Une équipe à taille humaine</h3>
          <p>NPG, c'est une équipe de professionnels au service des entreprises, des syndics de copropriété et des particuliers. De petite taille, nous nous adaptons aux besoins de chaque client : cette souplesse est un gage de qualité et de réactivité.</p>
        </article>

        <article class="h-why__cell">
          <h3>Un seul interlocuteur</h3>
          <p>Nous vous proposons un service à la carte, déterminé en fonction de vos besoins et de votre budget. Vous n'avez qu'un seul interlocuteur, du devis au suivi des interventions.</p>
        </article>

        <article class="h-why__cell">
          <h3>Un savoir-faire multiservices</h3>
          <p>Nous proposons toute une gamme de prestations pour répondre à vos besoins en matière d'hygiène et de propreté : bureaux, parties communes, sols, surfaces vitrées, espaces verts et nettoyage extérieur haute pression.</p>
        </article>

