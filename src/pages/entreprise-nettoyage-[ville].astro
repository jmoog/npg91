---
// src/pages/nettoyage-[ville].astro — Pages villes SEO local NPG (/nettoyage-<slug>/)
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';
import { SERVICES } from '../data/services';
import { VILLES, VILLES_MAP } from '../data/villes';

export function getStaticPaths() {
  return VILLES.map(v => ({ params: { ville: v.slug } }));
}

const { ville } = Astro.params;
const v = VILLES_MAP[ville as string];
if (!v) return Astro.redirect('/404');

// « à Massy » / « aux Ulis »
const aVille = v.prep ?? `à ${v.nom}`;
const canonical = `${SITE.url}/entreprise-nettoyage-${v.slug}/`;

// Villes voisines (maillage interne)
const voisines = v.voisines
  .map(s => VILLES_MAP[s])
  .filter(Boolean);

// Ancres voisines diversifiées (anti-suroptimisation)
const ancresVoisines = [
  (n: string) => `Nettoyage à ${n}`,
  (n: string) => n,
  (n: string) => `Entreprise de nettoyage à ${n}`,
  (n: string) => n,
  (n: string) => `Nettoyage à ${n}`,
];

// ── Cartes prestations : les 11 services reliés, priorité ville d'abord ──
// Ancres contextualisées « presta + ville » + photos NPG avec alt adapté.
const prioSlugs = v.services ?? [];
const orderedServices = [
  ...prioSlugs.map(sl => SERVICES.find(s => s.slug === sl)).filter(Boolean),
  ...SERVICES.filter(s => !prioSlugs.includes(s.slug)),
] as typeof SERVICES;
const prestaCards = orderedServices.map(s => {
  const libelle = s.serviceType ?? s.nom;
  return {
    nom:    s.nom,
    href:   `/services/${s.slug}/`,
    img:    s.heroImg,
    anchor: `${libelle} ${aVille}`,
    alt:    `${libelle} ${aVille} — NPG`,
  };
});

// ── Schema : Service (provider = #organization défini sur l'accueil) + Breadcrumb + FAQPage ──
const provider = {
  '@type': ['CleaningService', 'LocalBusiness'],
  '@id':   `${SITE.url}/#organization`,
  name:    SITE.nom,
  url:     SITE.url,
  telephone: SITE.tel.replace(/\s/g, '').replace(/^0/, '+33'),
  image:   `${SITE.url}${SITE.logo}`,
  address: {
    '@type':         'PostalAddress',
    streetAddress:   SITE.streetAddress,
    addressLocality: SITE.ville,
    postalCode:      SITE.cp,
    addressRegion:   'Essonne',
    addressCountry:  'FR',
  },
};

const service = {
  '@type':      'Service',
  '@id':        `${canonical}#service`,
  name:         `Entreprise de nettoyage ${aVille}`,
  serviceType:  'Nettoyage professionnel',
  description:  v.seoDesc,
  url:          canonical,
  provider,
  areaServed: {
    '@type':          'City',
    name:             v.nom,
    postalCode:       v.cp,
    containedInPlace: { '@type': 'AdministrativeArea', name: 'Essonne' },
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name:    `Prestations de nettoyage ${aVille}`,
    itemListElement: SERVICES.map(s => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name:    `${s.serviceType ?? s.nom} ${aVille}`,
        url:     `${SITE.url}/services/${s.slug}/`,
      },
    })),
  },
};

const breadcrumb = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: `Nettoyage ${aVille}`, item: canonical },
  ],
};

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: v.faq.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.r },
  })),
};

const schema = { '@context': 'https://schema.org', '@graph': [service, breadcrumb, faqSchema] };
---

<Layout
  title={v.seoTitle}
  description={v.seoDesc}
  canonical={canonical}
  schema={schema}
  lcpImage={v.heroImg}
>

  <!-- 1. HERO (design de la page d'accueil) -->
  <section class="h-hero">
    <div class="h-hero__inner">
      <div class="h-hero__txt">
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a><span>›</span><span>Nettoyage {aVille}</span>
        </nav>
        <h1 class="h-hero__title">
          <span class="h-hero__line">Société de nettoyage</span>
          <span class="h-hero__line h-hero__line--accent">{aVille}<i class="h-hero__underline"></i></span>
        </h1>
        <p class="h-hero__brand">Société NPG</p>
        <p class="h-hero__hook">Besoin d'un professionnel du nettoyage {aVille}&nbsp;?</p>
        <p class="h-hero__sub" set:html={v.heroDesc}></p>
        <a href={`tel:${SITE.telLink}`} class="h-hero__cta" aria-label={`Appeler le ${SITE.tel}`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="6" y="2" width="12" height="20" rx="2.5"/>
            <line x1="11" y1="18" x2="13" y2="18"/>
          </svg>
          {SITE.tel}
        </a>
      </div>
    </div>

    <div class="h-hero__img">
      <img src={v.heroImg} alt={v.heroAlt} loading="eager" fetchpriority="high" decoding="async" width="1500" height="1100">
    </div>

    <aside class="h-side">
      <a href={`tel:${SITE.telLink}`} class="h-side__item" aria-label={`Appeler le ${SITE.tel}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="h-side__lbl">Appeler</span>
        <span class="h-side__phone">{SITE.tel}</span>
      </a>
      <a href="/contact/" class="h-side__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/></svg>
        <span>Message</span>
      </a>
      <a href={`https://wa.me/33${SITE.telLink.replace(/^0/, '')}`} class="h-side__item h-side__item--wa" target="_blank" rel="noopener" aria-label="Discuter sur WhatsApp">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        <span>WhatsApp</span>
      </a>
    </aside>
  </section>

  <!-- 2. CONTENU LOCAL (unique par ville) -->
  <div class="content-wrap">
    <div class="container ville-wrap">

      <p class="ville-intro">{v.intro}</p>

      {v.chapitres.map(ch => (
        <>
          <h2>{ch.h2}</h2>
          <p set:html={ch.texte}></p>
        </>
      ))}

    </div>
  </div>

  <!-- 3. Prestations : les 11 services reliés, ancres contextualisées + photos -->
  <section class="ville-presta">
    <div class="container">
      <div class="h-prest__head">
        <span class="h-prest__bar"></span>
        <h2>Nos prestations de nettoyage {aVille}</h2>
      </div>
      <p class="ville-presta__lead">Entreprise de nettoyage {aVille}, NPG met à votre service l'ensemble de ses prestations. Cliquez sur un service pour découvrir le détail de notre intervention {aVille} et dans tout l'Essonne&nbsp;(91).</p>
      <div class="ville-presta__grid">
        {prestaCards.map(c => (
          <article class="vp-card">
            <a href={c.href} class="vp-card__media" aria-label={c.anchor} tabindex="-1">
              <img src={c.img} alt={c.alt} width="400" height="260" loading="lazy" decoding="async" />
            </a>
            <div class="vp-card__body">
              <h3>{c.nom}</h3>
              <a href={c.href} class="vp-card__link">{c.anchor}<span aria-hidden="true">→</span></a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. FAQ ville -->
  <section class="svc-faq">
    <div class="container">
      <div class="h-prest__head">
        <span class="h-prest__bar"></span>
        <h2>Questions fréquentes — nettoyage {aVille}</h2>
      </div>
      <div class="svc-faq__grid">
        {v.faq.map(f => (
          <article class="svc-faq__card">
            <h3>{f.q}</h3>
            <p>{f.r}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Villes voisines (maillage interne) -->
  {voisines.length > 0 && (
    <section class="ville-voisines">
      <div class="container">
        <div class="h-prest__head">
          <span class="h-prest__bar"></span>
          <h2>Nettoyage dans les communes voisines</h2>
        </div>
        <div class="ville-voisines__pills">
          {voisines.map((vo, i) => (
            <a href={`/entreprise-nettoyage-${vo.slug}/`} title={`Entreprise de nettoyage à ${vo.nom} — NPG`}>
              {ancresVoisines[i % ancresVoisines.length](vo.nom)}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 6. CTA final -->
  <section class="ville-cta">
    <div class="container">
      <div class="ville-cta__box">
        <h2>Votre entreprise de nettoyage {aVille}</h2>
        <p>NPG se déplace gratuitement {aVille} et dans tout l'Essonne&nbsp;(91) pour évaluer vos besoins et vous remettre une proposition détaillée, sans engagement. Du lundi au vendredi, de 7h à 21h.</p>
        <div class="ville-cta__btns">
          <a href={`tel:${SITE.telLink}`} class="btn btn--red">{SITE.tel}</a>
          <a href="/contact/" class="btn btn--white">Envoyer un message</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ══ HERO (repris du design de la page d'accueil) ══ */
.h-hero { background:#0a0a14; position:relative; overflow:hidden; min-height:560px; }
.h-hero__img { position:absolute; inset:0 0 0 38%; z-index:1; overflow:hidden; }
.h-hero__img::before { content:""; position:absolute; inset:0; background:linear-gradient(95deg, #0a0a14 0%, rgba(10,10,20,.85) 18%, transparent 45%); z-index:2; pointer-events:none; }
.h-hero__img::after { content:""; position:absolute; top:0; bottom:0; left:-2px; width:22%; background:#0a0a14; clip-path:polygon(0 0, 100% 0, 0 100%); z-index:2; }
.h-hero__img img { width:100%; height:100%; object-fit:cover; object-position:center center; display:block; }
.h-hero__inner { max-width:var(--max); margin:0 auto; padding:3.5rem 1.5rem 3.5rem; display:grid; grid-template-columns:minmax(0,56%) 1fr; gap:2rem; align-items:center; position:relative; z-index:3; min-height:560px; }
.h-hero__txt { color:var(--white); position:relative; max-width:600px; }
.h-hero__txt .breadcrumb { margin-bottom:1.1rem; }
/* Taille réduite + recalculée pour que chaque segment tienne sur UNE ligne
   (2 lignes au total : « Société de nettoyage » / « à VILLE »), y compris le nom
   le plus long (Sainte-Geneviève-des-Bois) et sur petits écrans. */
.h-hero__title { font-family:var(--font); font-weight:900; font-style:italic; font-size:clamp(1.05rem,4.4vw,2.35rem); line-height:1.12; letter-spacing:-.03em; margin:0 0 1.2rem; text-transform:uppercase; text-shadow:0 2px 16px rgba(0,0,0,.4); white-space:nowrap; }
.h-hero__line { display:block; color:var(--white); }
.h-hero__line--accent { color:var(--white); position:relative; display:inline-block; }
.h-hero__underline { position:absolute; left:0; right:6%; bottom:-8px; height:9px; background:var(--red); transform:skewX(-14deg); border-radius:2px; }
.h-hero__brand { display:inline-block; color:#fff; background:var(--blue); padding:.1rem .6rem; border-radius:6px; font-size:clamp(1rem,2vw,1.25rem); font-weight:800; font-style:italic; text-transform:uppercase; letter-spacing:.02em; line-height:1.2; margin:.2rem 0 1.1rem; }
.h-hero__hook { color:var(--white); font-size:clamp(.95rem,1.6vw,1.18rem); font-weight:700; margin:0 0 .85rem; text-shadow:0 1px 6px rgba(0,0,0,.4); text-wrap:balance; max-width:34ch; }
.h-hero__sub { font-size:1rem; line-height:1.6; color:rgba(255,255,255,.88); max-width:560px; margin:0 0 2rem; text-shadow:0 1px 6px rgba(0,0,0,.4); }
.h-hero__sub strong { color:var(--white); font-weight:700; }
.h-hero__cta { display:inline-flex; align-items:center; gap:.65rem; background:var(--red); color:var(--white); padding:1.05rem 2.2rem; border-radius:8px; font-weight:700; font-size:1.05rem; text-decoration:none; transition:all var(--transition); box-shadow:0 10px 30px rgba(78,156,58,.45); }
.h-hero__cta:hover { background:var(--red-d); transform:translateY(-2px); }
.h-side { position:absolute; top:50%; right:1.5rem; transform:translateY(-50%); display:flex; flex-direction:column; background:var(--white); border-radius:16px; box-shadow:0 12px 32px rgba(0,0,0,.18); overflow:hidden; z-index:5; width:116px; }
.h-side__item { display:flex; flex-direction:column; align-items:center; gap:.35rem; padding:1rem .5rem; color:var(--text); text-decoration:none; font-size:.72rem; font-weight:600; text-align:center; border-bottom:1px dashed var(--border); transition:background var(--transition); line-height:1.2; }
.h-side__item:last-child { border-bottom:none; }
.h-side__item:hover { background:var(--blue-l); color:var(--blue-d); }
.h-side__item svg { width:22px; height:22px; color:var(--blue); }
.h-side__item:hover svg { color:var(--blue-d); }
.h-side__lbl { display:block; font-size:.72rem; }
.h-side__phone { display:block; font-size:.82rem; font-weight:700; color:var(--blue-d); letter-spacing:-.01em; white-space:nowrap; }
@media (max-width:980px) {
  .h-hero { min-height:auto; display:flex; flex-direction:column; }
  .h-hero__img { position:relative; inset:auto; height:280px; width:100%; order:-1; }
  .h-hero__img::before, .h-hero__img::after { display:none; }
  .h-hero__inner { grid-template-columns:1fr; padding:0 1.25rem 2rem; min-height:auto; display:flex; flex-direction:column; gap:1.5rem; text-align:center; }
  .h-hero__txt { padding-top:1.6rem; margin:0 auto; max-width:560px; display:flex; flex-direction:column; align-items:center; }
  .h-hero__txt .breadcrumb { justify-content:center; }
  .h-hero__title, .h-hero__hook, .h-hero__sub { text-align:center; }
  .h-hero__sub { max-width:100%; margin-left:auto; margin-right:auto; }
  .h-hero__cta { margin:0 auto; }
  .h-hero__underline { right:4%; left:4%; }
  .h-side { position:static; transform:none; flex-direction:row; width:calc(100% - 2.5rem); max-width:540px; margin:1.25rem auto 0; }
  .h-side__item { flex:1; border-bottom:none; border-right:1px dashed var(--border); padding:.8rem .35rem; }
  .h-side__item:last-child { border-right:none; }
}
/* Comme la page d'accueil : barre Appeler/Message/WhatsApp masquée sur mobile
   (les CTA du hero + footer + FAB suffisent — évite le doublon). */
@media (max-width:540px) { .h-side { display:none; } }

/* ── Titre de section (barre rouge + h2) — autonome (.h-prest__head non chargé hors accueil) ── */
.h-prest__head { display:flex; align-items:center; gap:.85rem; margin-bottom:1.5rem; }
.h-prest__bar { width:42px; height:4px; border-radius:4px; background:var(--red); flex-shrink:0; }
.h-prest__head h2 { margin:0; font-size:clamp(1.3rem,2.4vw,1.7rem); line-height:1.25; }

/* ── Contenu local ── */
.ville-wrap { max-width:860px; }
.ville-intro { font-size:1.05rem; line-height:1.7; color:var(--text-mid); margin-bottom:2.2rem; }
.ville-wrap h2 { font-size:clamp(1.2rem,2.2vw,1.55rem); margin:2.2rem 0 .7rem; color:var(--blue-d); }
.ville-wrap p { line-height:1.75; color:var(--text-mid); margin-bottom:1rem; }

/* ── Section prestations (cartes services) ── */
.ville-presta { background:var(--light); padding:4rem 0; }
.ville-presta__lead { max-width:760px; line-height:1.7; color:var(--text-mid); margin:-.4rem 0 2.2rem; }
.ville-presta__grid {
  display:grid; grid-template-columns:repeat(3, 1fr); gap:1.4rem;
}
.vp-card {
  background:#fff; border:1px solid var(--border); border-radius:14px;
  overflow:hidden; display:flex; flex-direction:column;
  transition:transform var(--transition), box-shadow var(--transition);
}
.vp-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-md); }
.vp-card__media { display:block; aspect-ratio:16/10; overflow:hidden; }
.vp-card__media img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .4s ease; }
.vp-card:hover .vp-card__media img { transform:scale(1.05); }
.vp-card__body { padding:1.1rem 1.2rem 1.3rem; display:flex; flex-direction:column; gap:.5rem; flex:1; }
.vp-card__body h3 { margin:0; font-size:1.02rem; color:var(--blue-d); line-height:1.3; }
.vp-card__link {
  margin-top:auto; display:inline-flex; align-items:center; gap:.4rem;
  color:var(--blue); font-weight:600; font-size:.9rem; line-height:1.35;
}
.vp-card__link span { color:var(--red); transition:transform var(--transition); }
.vp-card:hover .vp-card__link { color:var(--blue-d); }
.vp-card:hover .vp-card__link span { transform:translateX(3px); }

@media (max-width:900px) { .ville-presta__grid { grid-template-columns:repeat(2,1fr); } }
@media (max-width:560px) { .ville-presta__grid { grid-template-columns:1fr; } }

/* ── CTA final (boîte bleue soignée) ── */
.ville-cta { padding:4rem 0; }
.ville-cta__box {
  background:linear-gradient(145deg, var(--blue-d) 0%, var(--blue) 100%);
  border-radius:20px; padding:2.8rem 2rem; text-align:center;
  max-width:880px; margin:0 auto; box-shadow:var(--shadow-lg);
}
.ville-cta__box h2 { color:#fff; margin:0 0 .8rem; font-size:clamp(1.2rem,2.4vw,1.7rem); line-height:1.3; text-wrap:balance; }
.ville-cta__box p { color:rgba(255,255,255,.85); margin:0 auto 1.7rem; max-width:640px; line-height:1.65; }
.ville-cta__btns { display:flex; gap:.75rem; justify-content:center; flex-wrap:wrap; }

/* ── Villes voisines ── */
.ville-voisines { padding:3.5rem 0; }
.ville-voisines__pills { display:flex; flex-wrap:wrap; gap:.6rem; }
.ville-voisines__pills a {
  display:inline-flex; align-items:center; padding:.5rem 1.05rem;
  background:var(--blue-l); color:var(--blue-d); border-radius:50px;
  font-size:.86rem; font-weight:600; border:1px solid transparent;
  transition:all var(--transition);
}
.ville-voisines__pills a:hover { background:var(--blue); color:#fff; border-color:var(--blue-d); }
</style>
