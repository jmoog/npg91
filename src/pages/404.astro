---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';
---

<Layout
  title="Page introuvable — NPG"
  description="Page introuvable."
  canonical={`${SITE.url}/`}
  noindex={true}
>
  <section class="notfound">
    <div class="container notfound__inner">

      <!-- Colonne gauche -->
      <div class="notfound__left">
        <span class="notfound__code">404</span>
        <h1>Cette page est introuvable</h1>
        <p>La page que vous cherchez n'existe pas ou a été déplacée.<br>Pas de panique, retrouvons ensemble ce dont vous avez besoin.</p>

        <div class="notfound__btns">
          <a href="/" class="notfound__btn notfound__btn--red">← Retour à l'accueil</a>
          <a href="/devis-gratuit/" class="notfound__btn notfound__btn--outline">Devis gratuit</a>
        </div>

        <div class="notfound__links">
          <p>Pages utiles :</p>
          <ul>
            <li><a href="/#prestations">Nos prestations</a></li>
            <li><a href="/a-propos/">À propos</a></li>
            <li><a href="/galerie/">Galerie</a></li>
            <li><a href="/contact/">Contact</a></li>
            <li><a href="/devis-gratuit/">Devis gratuit</a></li>
          </ul>
        </div>
      </div>

      <!-- Colonne droite -->
      <div class="notfound__right">
        <div class="notfound__card">
          <h3>Besoin d'un devis de nettoyage ?</h3>
          <p>Bureaux, parties communes, vitres, sols, espaces verts — nous intervenons dans toute l'Essonne.</p>
          <a href={`tel:${SITE.telLink}`} class="notfound__btn notfound__btn--red notfound__btn--full">
            {SITE.tel} — Lun-Ven, 7h-21h
          </a>
          <div class="notfound__garantie">{SITE.garantie}</div>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
.notfound {
  background: linear-gradient(135deg, var(--blue) 0%, #0d2240 100%);
  min-height: calc(100vh - 80px);
  display: flex;
  align-items: center;
  padding: 5rem 0;
}
.notfound__inner {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 4rem;
  align-items: center;
}
.notfound__code {
  display: block;
  font-size: 7rem;
  font-weight: 900;
  color: rgba(255,255,255,.1);
  line-height: 1;
  margin-bottom: .25rem;
}
.notfound__left h1 { color: #fff; margin-bottom: 1rem; }
.notfound__left > p { color: rgba(255,255,255,.75); font-size: 1rem; margin-bottom: 2rem; line-height: 1.75; }
.notfound__btns { display: flex; flex-wrap: wrap; gap: .8rem; margin-bottom: 2.5rem; }
.notfound__btn { display: inline-flex; align-items: center; justify-content: center; padding: .75rem 1.75rem; border-radius: 50px; font-weight: 700; font-size: .9rem; transition: background .2s, transform .15s; text-decoration: none; white-space: nowrap; }
.notfound__btn--red { background: var(--red); color: #fff !important; }
.notfound__btn--red:hover { background: var(--red-d); transform: translateY(-2px); color: #fff !important; }
.notfound__btn--outline { background: transparent; color: #fff !important; border: 2px solid rgba(255,255,255,.5); }
.notfound__btn--outline:hover { background: rgba(255,255,255,.1); color: #fff !important; }
.notfound__btn--full { width: 100%; }
.notfound__links p { font-size: .75rem; color: rgba(255,255,255,.4); text-transform: uppercase; letter-spacing: .07em; margin-bottom: .75rem; }
.notfound__links ul { display: flex; flex-wrap: wrap; gap: .5rem; }
.notfound__links li a { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); color: rgba(255,255,255,.8); padding: .3rem .9rem; border-radius: 50px; font-size: .82rem; font-weight: 600; transition: background .2s; }
.notfound__links li a:hover { background: rgba(255,255,255,.15); color: #fff; }
.notfound__card { background: var(--white); border-radius: var(--r); padding: 2rem; text-align: center; box-shadow: var(--shadow-lg); }
.notfound__card h3 { color: var(--blue); margin-bottom: .75rem; font-size: 1.1rem; line-height: 1.35; }
.notfound__card > p { font-size: .88rem; color: var(--muted); margin-bottom: 1.5rem; line-height: 1.65; }
.notfound__tel2 { display: block; margin-top: .75rem; font-size: .9rem; font-weight: 700; color: var(--blue) !important; text-align: center; }
.notfound__tel2:hover { color: var(--red) !important; }
.notfound__garantie { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: .78rem; font-weight: 600; color: var(--muted); }
@media(max-width:900px) {
  .notfound__inner { grid-template-columns: 1fr; }
  .notfound__right { max-width: 380px; margin: 0 auto; width: 100%; }
  .notfound__code  { font-size: 5rem; }
}
@media(max-width:480px) {
  .notfound__btns { flex-direction: column; }
}
</style>
