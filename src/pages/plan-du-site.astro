---
// src/pages/plan-du-site.astro
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';

// Prestations (ancres de la page d'accueil tant que les pages dédiées n'existent pas)
const prestations = [
  { href: '/#nettoyage-bureaux', nom: 'Nettoyage de bureaux' },
  { href: '/#parties-communes',  nom: 'Parties communes & copropriétés' },
  { href: '/#surfaces-vitrees',  nom: 'Surfaces vitrées' },
  { href: '/#nettoyage-sols',    nom: 'Nettoyage et entretien des sols' },
  { href: '/#moquettes',         nom: 'Shampooing de moquettes' },
  { href: '/#espaces-verts',     nom: 'Entretien des espaces verts' },
  { href: '/#haute-pression',    nom: 'Nettoyage haute pression' },
  { href: '/#remise-en-etat',    nom: 'Nettoyage de fin de chantier' },
];
---

<Layout
  title="Plan du site — NPG"
  description="Plan du site de NPG, entreprise de nettoyage dans l'Essonne (91)."
  canonical={`${SITE.url}/plan-du-site`}
>

  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Accueil</a><span>›</span><span>Plan du site</span>
      </nav>
      <h1>Plan du site</h1>
    </div>
  </section>

  <div class="content-wrap">
    <div class="container sitemap">

      <div class="sitemap__section">
        <h2>Pages principales</h2>
        <ul class="sitemap__list">
          <li><a href="/">Accueil</a></li>
          <li><a href="/a-propos/">À propos</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/galerie/">Galerie</a></li>
          <li><a href="/devis-gratuit/">Devis gratuit</a></li>
          <li><a href="/mentions-legales/">Mentions légales</a></li>
          <li><a href="/politique-de-cookies-ue/">Politique de cookies</a></li>
        </ul>
      </div>

      <div class="sitemap__section">
        <h2>Nos prestations</h2>
        <ul class="sitemap__list">
          {prestations.map(p => (
            <li><a href={p.href}>{p.nom}</a></li>
          ))}
        </ul>
      </div>

    </div>
  </div>

</Layout>
