---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config';

const IMG = '/assets/img/photos-npg';

// Clé publique Turnstile (build-time) — voir devis-gratuit.astro
const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

const schema = {
  '@context': 'https://schema.org',
  '@type':    'ContactPage',
  url:        `${SITE.url}/contact/`,
  about: { '@id': `${SITE.url}/#organization` },
};
---

<Layout
  title="Contact — NPG, entreprise de nettoyage dans l'Essonne (91)"
  description="Joignez NPG, entreprise de nettoyage dans l'Essonne (91), par téléphone, email ou formulaire. Intervention dans tout le département, devis sur demande."
  canonical={`${SITE.url}/contact/`}
  schema={schema}
>

  <section class="page-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Accueil</a><span>›</span><span>Contact</span>
      </nav>
      <h1>Nous contacter</h1>
      <p class="page-hero__desc">Une question, une demande d'intervention ou un devis ? Notre équipe est à votre service du lundi au vendredi, de 7h à 21h.</p>
    </div>
  </section>

  <div class="content-wrap section--light">
    <div class="container">
      <div class="form-grid">

        <!-- Colonne gauche : coordonnées -->
        <div>
          <h2>Nous trouver dans l'Essonne</h2>
          <p>NPG, entreprise de nettoyage multiservices, intervient partout dans le département de l'Essonne. Nous adaptons nos horaires d'intervention en fonction de votre activité et de vos besoins.</p>

          <ul class="contact-list" style="margin-top:1.5rem">
            <li>
              <img src="/assets/icones/pin-map.svg" alt="" width="18" height="18" class="icone">
              <span>{SITE.adresse}</span>
            </li>
            <li>
              <img src="/assets/icones/mobile.svg" alt="" width="18" height="18" class="icone">
              <a href={`tel:${SITE.telLink}`}><strong>{SITE.tel}</strong></a>
            </li>
            <li>
              <img src="/assets/icones/email.svg" alt="" width="18" height="18" class="icone">
              <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
            </li>
          </ul>

          <p style="margin-top:1.25rem;color:var(--text-mid);">
            <strong>Horaires :</strong> du lundi au vendredi, de 7h00 à 21h00.<br>
            En fonction de votre activité, nous adaptons nos horaires d'intervention à votre besoin.
          </p>

          <p style="margin:1.5rem 0;">
            <img src={`${IMG}/camion-npg-devant-residence-npg.webp`} alt="Véhicule NPG dans l'Essonne" loading="lazy" style="width:100%;border-radius:14px;" />
          </p>

          <p>
            <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(SITE.adresse)}`} class="btn btn--outline" target="_blank" rel="noopener">
              <img src="/assets/icones/pin-map.svg" alt="" width="16" height="16" class="icone">
              Voir sur Google Maps
            </a>
          </p>
        </div>

        <!-- Colonne droite : formulaire -->
        <div class="form-wrap">
          <h3>Laissez-nous un message</h3>
          <p style="font-size:.92rem;color:var(--muted, #6b7280);margin-bottom:1.5rem;">Nous vous répondons dans les plus brefs délais.</p>

          <form id="contact-form" name="contact" method="POST" action="/api/devis/">
            <p style="position:absolute;left:-9999px" aria-hidden="true">
              <label>Ne pas remplir <input name="website" tabindex="-1" autocomplete="off"></label>
            </p>

            <div class="fg">
              <label for="c-nom">Nom</label>
              <input id="c-nom" type="text" name="nom" required autocomplete="name" placeholder="Votre nom">
            </div>

            <div class="form-row">
              <div class="fg">
                <label for="c-tel">Téléphone</label>
                <input id="c-tel" type="tel" name="tel" required autocomplete="tel" placeholder="06 12 34 56 78">
              </div>
              <div class="fg">
                <label for="c-email">Email</label>
                <input id="c-email" type="email" name="email" required autocomplete="email" placeholder="vous@exemple.com">
              </div>
            </div>

            <div class="fg">
              <label for="c-ville">Ville / Code postal</label>
              <input id="c-ville" type="text" name="ville" required placeholder="Montlhéry, 91310…">
            </div>

            <div class="form-row">
              <div class="fg">
                <label for="c-entreprise">Votre entreprise <span style="color:var(--muted);font-weight:400;">(optionnel)</span></label>
                <input id="c-entreprise" type="text" name="entreprise" autocomplete="organization" placeholder="Nom de votre société">
              </div>
              <div class="fg">
                <label for="c-secteur">Secteur d'activité <span style="color:var(--muted);font-weight:400;">(optionnel)</span></label>
                <input id="c-secteur" type="text" name="secteur" placeholder="Bureaux, copropriété, commerce…">
              </div>
            </div>

            <div class="fg">
              <label for="c-prestation">Type de prestation <span style="color:var(--muted);font-weight:400;">(optionnel)</span></label>
              <select id="c-prestation" name="prestation">
                <option value="">— Choisir —</option>
                <option value="nettoyage-bureaux">Nettoyage de bureaux / locaux</option>
                <option value="parties-communes">Parties communes de copropriété</option>
                <option value="surfaces-vitrees">Surfaces vitrées</option>
                <option value="nettoyage-sols">Nettoyage et entretien des sols</option>
                <option value="moquettes">Shampooing de moquettes</option>
                <option value="espaces-verts">Entretien des espaces verts</option>
                <option value="haute-pression">Nettoyage haute pression</option>
                <option value="fin-de-chantier">Nettoyage de fin de chantier</option>
                <option value="autre">Autre / plusieurs prestations</option>
              </select>
            </div>

            <div class="fg">
              <label for="c-message">Votre message</label>
              <textarea id="c-message" name="message" rows="5" required placeholder="Décrivez votre demande (type de locaux, prestation souhaitée, fréquence…)"></textarea>
            </div>

            {turnstileKey && (
              <div class="cf-turnstile" data-sitekey={turnstileKey} data-theme="light" style="margin-bottom:1rem;"></div>
            )}

            <button type="submit" class="btn btn--red btn--full" id="contact-submit">
              <img src="/assets/icones/email.svg" alt="" width="16" height="16" class="icone">
              Envoyer un message
            </button>
            <p id="contact-status" role="status" aria-live="polite" style="margin-top:1rem;font-size:.92rem;"></p>
          </form>

          {turnstileKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>}

          <script is:inline>
          (function () {
            var form = document.getElementById('contact-form');
            if (!form) return;
            var status = document.getElementById('contact-status');
            var submit = document.getElementById('contact-submit');
            form.addEventListener('submit', async function (e) {
              e.preventDefault();
              submit.disabled = true;
              status.style.color = '';
              status.textContent = 'Envoi en cours…';
              try {
                var fd = new FormData(form);
                var payload = {};
                fd.forEach(function (v, k) { payload[k] = v; });
                var res = await fetch('/api/devis/', {
                  method: 'POST',
                  headers: { 'content-type': 'application/json', 'accept': 'application/json' },
                  body: JSON.stringify(payload),
                });
                var data = await res.json().catch(function () { return {}; });
                if (res.ok && data.ok) {
                  window.location.href = '/merci/';
                  return;
                }
                status.style.color = '#c0392b';
                status.textContent = data.error || 'Une erreur est survenue. Merci de réessayer ou de nous appeler au 06 82 18 71 14.';
                submit.disabled = false;
                if (window.turnstile) window.turnstile.reset();
              } catch (err) {
                status.style.color = '#c0392b';
                status.textContent = 'Erreur réseau. Merci de réessayer ou de nous appeler au 06 82 18 71 14.';
                submit.disabled = false;
                if (window.turnstile) window.turnstile.reset();
              }
            });
          })();
          </script>
        </div>

      </div>
    </div>
  </div>

</Layout>
